# PostgreSQL — локально свой PG, в проде connection string из Neon
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/barbershop

# JWT — длинная случайная строка (openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-string

# Учётка единственного админа (пароль задаётся при первом запуске seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# CORS — origin фронта (локально Vite + прод Vercel), через запятую
CORS_ORIGINS=http://localhost:5173

# Render сам прокидывает $PORT в startCommand — переменную задавать не нужно
